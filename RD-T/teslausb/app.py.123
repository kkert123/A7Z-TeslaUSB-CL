#!/usr/bin/env python3
from flask import Flask, render_template, request, jsonify
from datetime import datetime
import os

app = Flask(__name__)

@app.route('/')
def index():
    return render_template('dashboard.html',
        service={'active': True, 'uptime': 'N/A'},
        sys_stats={'cpu_percent': 0, 'cpu_temp': None, 'cpu_temp_min': None, 'cpu_temp_avg': None, 'cpu_temp_max': None, 'mem_used_mb': 0, 'mem_total_mb': 1, 'mem_percent': 0, 'swap_used_mb': 0, 'swap_total_mb': 0, 'load_1min': 0, 'load_5min': 0, 'load_15min': 0},
        wifi={'connected': False, 'ssid': 'N/A', 'signal': None},
        ip_info={'local': 'N/A', 'tailscale': 'N/A'},
        disk_total=None,
        disk={},
        now=datetime.now().strftime("%H:%M:%S"),
        fmt_bytes=lambda b: f"{b/1024/1024:.2f} MB" if b else "0 MB"
    )

@app.route('/api/system/stats')
def api_stats():
    return jsonify({'success': True, 'time': datetime.now().strftime("%H:%M:%S")})

